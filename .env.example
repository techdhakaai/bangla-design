# AI Builder Platform - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# FRONTEND (apps/web) - Required for Vercel
# ============================================

# API URL - Your Cloudflare Workers API endpoint
# In development: http://localhost:8787
# In production: https://your-api.workers.dev or your custom domain
NEXT_PUBLIC_API_URL=http://localhost:8787

# ============================================
# BACKEND (apps/api-worker) - Cloudflare Workers
# ============================================
# Note: These are set in wrangler.toml secrets, not here
# Run: npx wrangler secret put OPENAI_API_KEY

# OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# Optional: Analytics & Monitoring
# ============================================

# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
